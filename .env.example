# Poseidon — Environment Configuration

# Server
PORT=3100
NODE_ENV=production

# JWT
JWT_SECRET=change-this-to-a-random-64-char-hex-string

# Database (optional — defaults to local SQLite file)
# DATABASE_PATH=/app/backend/data/poseidon.db

# Stripe (required for billing)
STRIPE_SECRET_KEY=sk_liv...your-key
STRIPE_WEBHOOK_SECRET=whsec_...your-webhook-secret (optional)

# SMTP (required for daily captain emails + cold outreach)
# SMTP_HOST=smtp.postmarkapp.com
# SMTP_PORT=587
# SMTP_USER=your-api-token
# SMTP_PASS=your-api-token
# SMTP_SECURE=false

# Telegram Bot (required for Telegram notifications)
# TELEGRAM_BOT_TOKEN=your-bot-token-from-@BotFath

# Meta Ads (required for ad campaigns)
# META_ACCESS_TOKEN=your-facebook-marketing-api-token
# META_AD_ACCOUNT_ID=your-ad-account-id (numbers only)
