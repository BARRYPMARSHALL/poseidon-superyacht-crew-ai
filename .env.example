# Poseidon — Environment Configuration
# Copy to .env and fill in values

# Server
PORT=3100
NODE_ENV=production

# JWT
JWT_SECRET=change-this-to-a-random-string

# Database (optional — defaults to local SQLite file)
# DATABASE_PATH=/app/backend/data/poseidon.db

# SMTP (for agent email alerts — optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-password

# Stripe (for subscription billing)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_SKIPPER=price_...
# STRIPE_PRICE_CAPTAIN=price_...
