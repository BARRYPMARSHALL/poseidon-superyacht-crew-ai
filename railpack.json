{
  "$schema": "https://railway.com/railpack.schema.json",
  "provider": "node",
  "nodeVersion": "22",
  "build": {
    "buildCommands": [
      "cd backend && npm install",
      "cd frontend && npm install && npm run build"
    ]
  },
  "deploy": {
    "startCommand": "node backend/node_modules/.bin/tsx backend/src/server.ts",
    "healthcheckCommand": "curl -f http://localhost:3100/api/health",
    "port": 3100
  }
}
